{
  "name": "taller-automotriz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:local": "concurrently -c \"cyan,magenta,yellow,blue,green\" -n \"GATEWAY,AUTH,OPERACIONES,CHAT,FRONTEND\" \"pnpm --filter @taller/api-gateway dev\" \"pnpm --filter @taller/ms-auth dev\" \"pnpm --filter @taller/ms-operaciones dev\" \"pnpm --filter @taller/ms-chat dev\" \"pnpm --filter @taller/frontend dev\"",
    "build": "pnpm -r run build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "gemini": "gemini"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@google/gemini-cli": "^0.42.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.1",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
